
<% if policy(Ativo).create? %>
  <%= render 'common/btn_new', resource: Ativo.new, label: 'Novo Ativo' %>
<% end %>

<table class="table table-striped table-sm">
  <thead class="thead-light">
  <tr>
    <th scope="col">Nome</th>
    <th scope="col">Descrição</th>
    <th scope="col">Tipo</th>
    <th scope="col">Moeda Negociação</th>
    <th scope="col">Moeda Exposição</th>
    <th scope="col">Data adição</th>
    <th></th>
  </tr>
  </thead>
<tbody>
  <% @ativos.each do |ativo| %>
    <tr>
      <td><%= link_to ativo.nome_amigavel, ativo_cotacoes_path(ativo) %></td>
      <td><%= ativo.descricao %></td>
      <td><%= ativo.tipo %></td>
      <td><%= ativo.moeda_negociacao %></td>
      <td><%= ativo.moeda_exposicao %></td>
      <td><%= display_data ativo.created_at %></td>
      <td>
        <%= link_to 'Editar', edit_ativo_path(ativo) if policy(ativo).edit? %>
      </td>
    </tr>
  <% end %>
</tbody>

</table>
