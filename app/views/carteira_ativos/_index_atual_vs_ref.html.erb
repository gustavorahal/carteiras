
<%= render 'common/titulo_pagina', titulo: "Seguindo carteira #{link_to @carteira.referencia.nome, referencia_path(@carteira.referencia)}" %>

<br>
<h3>Total Geral de <%= display_moeda @carteira_ativos.total_geral %> <small class="text-muted">em <%= display_data @data %></small></h3>
<br>

<div class="card">
  <div class="card-body">
    <table class="table table-borderless table-sm">
      <h5 class="card-title">Composição</h5>
      <tr><td></td><td><strong>Posição</strong></td><td><strong>Referência</strong></td></tr>
      <% @porcentagens_por_book_ref.each do |book, porcentagem_ref| %>
        <tr>
          <td><%= book %></td>
          <td><%= display_porcentagem @porcentagens_por_book_carteira[book] %></td>
          <td><%= display_porcentagem porcentagem_ref %></td>
        </tr>
      <% end %>
    </table>
  </div>
</div>

<div class="container">
  <table class="table table-sm">
    <thead class="thead-dark">
    <tr>
      <th scope="col">Ativo</th>
      <th scope="col">Posição</th>
      <th scope="col">Referência</th>
      <th scope="col">Diff valor</th>
      <th scope="col">Diff Quant</th>
      <th scope="col"></th>
    </tr>
    </thead>
    <tbody>

    <% @referencia_ativos_por_book.each do |book, ativos| %>
      <tr class="table-primary">
        <td>
          <h6><%= book %></h6>
        </td>
        <td>
          <h6><%= display_porcentagem @porcentagens_por_book_carteira[book] %></h6>
        </td>
        <td>
          <h6><%= display_porcentagem @porcentagens_por_book_ref[book] %></h6>
        </td>
        <td></td><td></td><td></td>
      </tr>
      <% ativos.each do |ativo| %>
        <% if @carteira_lista_de_ativos.include?(ativo) %>
          <% span_class = '' %>
          <% @carteira_ativos_restante.delete ativo %>
        <% else %>
          <% span_class = 'bg-warning' %>
        <% end %>
        <tr>
          <td><span class="<%= span_class %>"><%= link_to ativo.nome_amigavel, carteira_ativo_path(@carteira, ativo) %></span></td>
          <td><span class="<%= span_class %>"><%= display_porcentagem @carteira_ativos.porcentagem_ativo(ativo) %></span></td>
          <td><span class="<%= span_class %>"><%= display_porcentagem @carteira.referencia.porcentagem(ativo) %></span></td>
          <td>
            <span class="<%= span_class %>">
              <% diff_valor_brl = @carteira_ativos_referencia.diff_valor_referencia_brl(ativo) %>
              <%= display_moeda(diff_valor_brl, cores: true) %>
              <% if ativo.usd? %>
                <% diff_valor_usd = @carteira_ativos_referencia.diff_valor_referencia_usd(ativo) %>
                (<%= display_moeda(diff_valor_usd, cores: true, moeda: ativo.moeda) %>)
              <% end %>
            </span>
          </td>
          <td>
            <% if ativo.usd? %>
              <% quant = diff_valor_usd / ativo.ultima_cotacao.valor_unit %>
            <% else %>
              <% quant = diff_valor_brl / ativo.ultima_cotacao.valor_unit %>
            <% end %>
            <%= quant.round(4) %>
          </td>
          <td>
            <% quant.negative? ? operacao = 'C' : operacao = 'V' %>
            <% ap = @carteira_ativos.busca_ativo_posicao(ativo) %>
            <% unless ap.nil? %>
              <%= render 'common/btn_oper_corretora', corretora: ap.corretora,
                                                      ativo: ativo, operacao: operacao %>
            <% end %>
          </td>
        </tr>
      <% end %>
    <% end %>

    <!-- Ativos que não estão na referencia -->
    <tr class="table-primary">
      <td><h6><i>NÃO ESTÃO EM REFERÊNCIA</i></h6></td>
      <td></td>
      <td></td>
      <td></td>
    </tr>
    <% span_class = 'font-weight-light' %>
    <% @carteira_ativos_restante.each do |ativo| %>
      <tr>
        <td><span class="<%= span_class %>"><%= link_to ativo.nome_amigavel, carteira_ativo_path(@carteira, ativo) %></span></td>
        <td><span class="<%= span_class %>"><%= display_porcentagem @carteira_ativos.porcentagem_ativo(ativo) %></span></td>
        <td></td>
        <td></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>