
<%= render 'common/titulo_pagina', titulo: "Book em #{display_data @data}" %>

<table class="table table-striped table-sm">
  <tbody>
  <% book_atual = '' %>
  <% @carteira_posicao_caps.each do |cap| %>
    <% if book_atual != cap.carteira_ativo.book %>
      <tr class="table-primary">
        <td>
          <h6><%= cap.carteira_ativo.book %></h6>
        </td>
        <td> <!-- Rendimento --> </td>
        <td>
          <h6><%= display_moeda @carteira_posicao.valor_por_book[cap.carteira_ativo.book] %>
            (<%= display_porcentagem @carteira_posicao.porcentagem_por_book[cap.carteira_ativo.book] %>) </h6>
        </td>
        <td><!-- Quantidade --></td>
        <td>Preço</td>
        <td>Preço Médio</td>
      </tr>
      <% book_atual = cap.carteira_ativo.book %>
    <% end %>
    <tr>
      <td><%= link_to cap.carteira_ativo.nome_amigavel, carteira_carteira_posicao_path(@carteira, cap.carteira_ativo) %>
        <small>desde <%= display_data cap.data_montagem %> </small></td>
      <td><%= display_rentabilidade cap %></td>
      <td><%= display_moeda cap.valor_posicao, moeda: cap.ativo.moeda, cores: true %>
        (<%= display_porcentagem @carteira_posicao.porcentagem_carteira_ativo(cap.carteira_ativo) %>)
      </td>
      <td><%= display_numero cap.quantidade %></td>
      <td><%= display_preco_atual cap %></td>
      <td><%= display_preco_medio cap %></td>
    </tr>
  <% end %>
  </tbody>
</table>
