<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Ativo</th>
    <th scope="col">Posição<br></th>
    <th scope="col">Quantidade<br></th>
  </tr>
  </thead>

  <tbody>
  <% @carteira_posicao.carteira_ativos_por_corretora.each do |corretora_nome, tipos|  %>
    <tr class="table-primary">
      <td colspan="3">
        <h6><%= corretora_nome %></h6>
      </td>
    </tr>
    <% tipos.each do |tipo, carteira_ativos| %>
      <tr class="table-dark">
        <td colspan="3">
          <h6><%= tipo.upcase %></h6>
        </td>
      </tr>
      <% carteira_ativos.each do |ca| %>
        <tr>
          <td><%= link_to ca.nome_amigavel, carteira_carteira_posicao_path(@carteira, ca) %></td>
          <td><%= display_moeda ca.valor_posicao %></td>
          <td><%= display_numero ca.quantidade %></td>
        </tr>
      <% end %>
    <% end %>
  <% end %>
  </tbody>

</table>