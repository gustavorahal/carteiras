<table class="table table-striped table-sm">
  <tbody>
  <% book_atual = '' %>
  <% @carteira_posicao.carteira_ativos.each do |ca| %>
    <% if book_atual != ca.book %>
      <tr class="table-primary">
        <td>
          <h6><%= ca.book %></h6>
        </td>
        <td> <!-- Rendimento --> </td>
        <td>
          <h6><%= display_moeda @carteira_posicao.valor_por_book[ca.book] %>
            (<%= display_porcentagem @carteira_posicao.porcentagem_por_book[ca.book] %>) </h6>
        </td>
        <td><!-- Quantidade --></td>
        <td>Preço Médio</td>
        <td>Preço Atual</td>
      </tr>
      <% book_atual = ca.book %>
    <% end %>
    <tr>
      <td><%= link_to ca.nome_amigavel, carteira_carteira_ativo_path(@carteira, ca) %>
                <small>desde <%= display_data ca.data_montagem %> </small></td>
      <td><%= display_porcentagem ca.rentabilidade(@data_fim), cores=true %></td>
      <td><%= display_moeda ca.valor_posicao, cores: true %>
          (<%= display_porcentagem @carteira_posicao.porcentagem_carteira_ativo(ca) %>)
      </td>
      <td><%= display_numero ca.quantidade %></td>
      <td><%= display_moeda ca.preco_medio(@data_fim) %></td>
      <td><%= display_moeda ca.cotacao.valor_unit_moeda %> <small>(<%= display_data ca.cotacao.data %>)</small></td>
    </tr>
  <% end %>
  </tbody>
</table>
