
<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Corretora</th>
    <th scope="col">Ativo</th>
    <th scope="col">Posição<br></th>
    <th scope="col">Quantidade<br></th>
    <th scope="col">Tipo</th>
  </tr>
  </thead>

  <tbody>
    <% @carteira_posicao.carteira_ativos_por_corretora.each do |corretora, carteira_ativos|  %>
        <% carteira_ativos.each do |ca| %>
          <tr>
            <td><%= corretora %></td>
            <td><%= link_to ca.nome_amigavel, carteira_carteira_ativo_path(@carteira, ca) %></td>
            <td><%= display_moeda ca.valor_posicao %></td>
            <td><%= display_numero ca.quantidade %></td>
            <td><%= ca.ativo.tipo %></td>
          </tr>
        <% end %>
    <% end %>
  </tbody>

</table>