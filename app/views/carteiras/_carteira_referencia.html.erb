<%= render 'common/btn_new',
           url: new_carteira_carteira_ativo_path(@carteira),
           label: 'Novo ativo' %>

<div class="container">
  <table class="table table-striped table-sm">
    <thead class="thead-dark">
      <tr>
        <th scope="col">Ativo</th>
        <th scope="col">Peso</th>
        <th scope="col">Corretora</th>
        <th scope="col"></th>
      </tr>
    </thead>
    <tbody>
      <tr class="table-primary text-center">
        <td colspan="4">
          <h5>Total <%= display_porcentagem @carteira.ref_books_porcentagem_soma %></h5>
        </td>
      </tr>
      <% book = '' %>
      <% @carteira_ativos.each do |ca| %>
        <% if book != ca.book %>
          <% book = ca.book %>
          <% book_percent = @carteira.ref_books_porcentagem[book] %>
          <tr class="table-primary text-center">
            <td colspan="4">
              <h6><%= book %> (<%= display_porcentagem book_percent %>)</h6>
            </td>
          </tr>
      <% end %>
        <tr>
          <td><%= link_to ca.nome_amigavel, carteira_carteira_ativo_path(@carteira, ca) %></td>
          <td><%= display_porcentagem ca.porcentagem %></td>
          <td><%= ca.corretora.nome %></td>
          <td><%= link_to 'editar', edit_carteira_carteira_ativo_path(@carteira, ca) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>