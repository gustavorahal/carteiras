<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Ativo</th>
    <th scope="col">% Carteira</th>
    <th scope="col">Rendimento</th>
    <th scope="col">Posição</th>
    <th scope="col">Quantidade</th>
    <th scope="col">Preço Médio</th>
    <th scope="col">Preço Atual</th>
  </tr>
  </thead>

  <tbody>
  <% book_atual = '' %>
  <% @carteira_posicao.ativos_posicoes.each do |ativo_posicao| %>
    <% if book_atual != ativo_posicao.book %>
      <tr class="table-primary text-center">
        <td colspan="7">
          <h5><%= ativo_posicao.book %>
            (<%= display_porcentagem @carteira_posicao.porcentagem_por_book[ativo_posicao.book] %>)</h5>
        </td>
      </tr>
      <% book_atual = ativo_posicao.book %>
    <% end %>
    <tr>
      <td><%= ativo_posicao.nome_ativo %> <small>desde <%= display_data ativo_posicao.data_montagem %> </small></td>
      <td><%= display_porcentagem(ativo_posicao.valor_posicao/@carteira_posicao.total_geral * 100) %></td>
      <td><%= display_porcentagem ativo_posicao.rentabilidade, cores=TRUE %></td>
      <td><%= display_moeda ativo_posicao.valor_posicao, cores: true %></td>
      <td><%= display_numero ativo_posicao.quantidade %></td>
      <td><%= display_moeda ativo_posicao.preco_medio %></td>
      <td><%= display_moeda ativo_posicao.preco_atual %> <small>(<%= display_data ativo_posicao.preco_atual_data %>)</small></td>
    </tr>
  <% end %>
  </tbody>
</table>
