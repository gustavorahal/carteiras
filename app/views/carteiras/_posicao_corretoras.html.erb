
<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Corretora</th>
    <th scope="col">Ativo</th>
    <th scope="col">Posição<br></th>
    <th scope="col">Quantidade<br></th>
    <th scope="col">Tipo</th>
  </tr>
  </thead>

  <tbody>
    <% @carteira_posicao.ativos_posicoes_por_corretora.each do |corretora, ativos_posicao|  %>
        <% ativos_posicao.each do |ativo_posicao| %>
          <tr>
            <td><%= corretora %></td>
            <td><%= ativo_posicao.nome_amigavel %></td>
            <td><%= display_moeda ativo_posicao.valor_posicao %></td>
            <td><%= display_numero ativo_posicao.quantidade %></td>
            <td><%= ativo_posicao.tipo_ativo %></td>
          </tr>
        <% end %>
    <% end %>
  </tbody>

</table>