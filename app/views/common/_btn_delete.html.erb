<% size = local_assigns.fetch :size, '' %>
<% disabled = local_assigns.fetch :disabled, false %>
<% show_label = local_assigns.fetch :show_label, false %>
<% label = show_label ? 'Deletar' : '' %>
<% url = local_assigns.fetch :url, false %>

<%= button_to bootstrap_icon("x-square-fill") + " #{label}",
              url,
              class: "btn btn-link #{size} text-danger",
              method: :delete,
              data: { "turbo-confirm": "Você tem certeza que deseja deletar \"#{resource.to_s}\"?",
                      "confirm": "Você tem certeza que deseja deletar \"#{resource.to_s}\"?"},
              disabled: disabled
%>
