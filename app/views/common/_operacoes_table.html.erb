
<% mostra_nome = local_assigns.fetch :mostra_nome, true %>
<% operacoes = local_assigns.fetch :operacoes, [] %>

<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Data</th>
    <% if mostra_nome  %>
      <th scope="col">Ativo</th>
    <% end %>
    <th scope="col">Corretora</th>
    <th scope="col">Oper.</th>
    <th scope="col">M/D</th>
    <th scope="col">Quant.</th>
    <th scope="col">Valor Unit.</th>
    <th scope="col">Valor Total</th>
    <th scope="col">USDBRL</th>
    <th scope="col">Obs.</th>
    <th scope="col">C.O.</th>
    <th scope="col"></th>
  </tr>
  </thead>
  <tbody>
  <% operacoes.each do |oper| %>
    <tr>
      <td><%= display_data oper.data %></td>
      <% if mostra_nome  %>
        <td><%= link_to oper.ativo.nome_amigavel,
                        posicao_ativo_path(oper.carteira, oper.ativo) %></td>
      <% end %>
      <td><%= oper.corretora.nome %></td>
      <td><%= oper.operacao.capitalize %></td>
      <td><%= oper.mon_ou_des %></td>
      <td><%= display_numero oper.quantidade %></td>
      <td><%= display_moeda oper.valor_unit, moeda: oper.ativo.moeda %></td>
      <td><%= display_moeda (oper.quantidade * oper.valor_unit), moeda: oper.ativo.moeda, cores: true %></td>
      <td><%= display_moeda oper.usdbrl %></td>
      <td>
        <small><%= oper.observacao.nil? ? oper.observacao : oper.observacao.html_safe %></small>
        <% if oper.operacao_sys %>
          <span class="badge badge-pill badge-info">Operação de sistema</span>
        <% end %>
      </td>
      <td><%= display_moeda oper.custos_operacionais, moeda: oper.ativo.moeda %></td>
      <td><%= link_to 'Editar', edit_carteira_operacao_path(params[:carteira_id], oper) %></td>
    </tr>
  <% end %>
  </tbody>

</table>
