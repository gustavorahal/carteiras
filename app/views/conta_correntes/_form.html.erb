<%= bootstrap_form_for [@carteira, @conta_corrente], layout: :horizontal do |f| %>

  <% if @conta_corrente.errors[:base].present? %>
    <%= f.alert_message 'Favor corrigir o(s) erro(s) abaixo. ' + @conta_corrente.errors[:base][0] %>
  <% else %>
    <%= f.alert_message 'Favor corrigir o(s) erro(s) abaixo.' %>
  <% end %>

  <%= f.select :moeda, %w[BRL USD] %>
  <%= f.collection_select :corretora_id, @corretoras, :id, :nome %>
  <%= f.hidden_field :carteira_id, value: @carteira.id %>

  <%= f.form_group do %>
    <%= f.submit 'Salvar' %>
    <%= link_to 'Cancelar', :back, class: 'btn btn-link' %>
  <% end %>

<% end %>