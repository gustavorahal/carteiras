<%= render 'common/titulo_pagina', titulo: "Conta Corrente #{@conta_corrente.corretora.nome} (#{@conta_corrente.moeda}) de carteira #{@carteira.nome} em #{display_data @data}" %>

<h6>Saldo <%= display_moeda @conta_corrente.saldo(@data), moeda: @conta_corrente.moeda %></h6>

<%= render 'common/btn_new', url: new_carteira_conta_corrente_extrato_path(@carteira, @conta_corrente), label: 'Nova entrada' %>

<%= bootstrap_form_tag url: import_carteira_conta_corrente_extratos_path(@carteira, @conta_corrente) do |f| %>
  <%= hidden_field_tag :conta_corrente_id, @conta_corrente.id %>
  <%= f.file_field :file, label: 'Importar extrato', placeholder: 'Arquivo de extrato' %>

  <%= f.submit 'Importar' %>
<% end %>

<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Liquidação</th>
    <th scope="col">Movimentação</th>
    <th scope="col">Descrição</th>
    <th scope="col">Valor</th>
    <th scope="col">Processado?</th>
  </tr>
  </thead>

  <tbody>
  <% @extratos.each do |extrato| %>
    <tr>
      <td><%= display_data extrato.liquidacao %></td>
      <td><%= display_data extrato.movimentacao %></td>
      <td><%= extrato.descricao %></td>
      <td><%= display_moeda extrato.valor, moeda: @conta_corrente.moeda, cores: true %></td>
      <td><%= extrato.processado %></td>
    </tr>
  <% end %>
  </tbody>
</table>