<h1>Cotação manual</h1><%= form_with model: @cotacao, url: cotacoes_ativos_path do |f| %><div class="mb-3"><%= f.label :ativo_id %><%= f.collection_select :ativo_id, @ativos, :id, :codigo, {}, class: "form-select" %></div><div class="mb-3"><%= f.label :data %><%= f.date_field :data, class: "form-control" %></div><div class="mb-3"><%= f.label :preco %><%= f.number_field :preco, step: :any, class: "form-control" %></div><div class="mb-3"><%= f.label :fonte_cotacao_id %><%= f.collection_select :fonte_cotacao_id, @fontes, :id, :nome, {}, class: "form-select" %></div><%= f.submit class: "btn btn-primary" %><% end %>
