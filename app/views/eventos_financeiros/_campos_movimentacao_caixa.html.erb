<div class="row g-3">
  <div class="col-md-6"><%= d.label :conta_caixa_id, "Conta de caixa" %><%= d.collection_select :conta_caixa_id, @contas_caixa, :id, :nome_completo, {}, class: "form-select" %></div>
  <div class="col-md-3"><%= d.label :natureza %><%= d.select :natureza, MovimentacaoCaixa.naturezas.keys.map { |n| [n.humanize, n] }, {}, class: "form-select" %></div>
  <div class="col-md-3"><%= d.label :direcao %><%= d.select :direcao, MovimentacaoCaixa.direcoes.keys.map { |n| [n.humanize, n] }, {}, class: "form-select" %></div>
  <div class="col-md-6"><%= d.label :valor %><%= d.number_field :valor, step: :any, min: 0, class: "form-control" %></div>
  <div class="col-md-6"><%= d.label :data_efetiva %><%= d.date_field :data_efetiva, value: Date.current, class: "form-control" %></div>
</div>
