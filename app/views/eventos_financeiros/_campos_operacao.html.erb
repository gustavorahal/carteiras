<div class="row g-3">
  <div class="col-md-6"><%= d.label :conta_investimento_id, "Conta" %><%= d.collection_select :conta_investimento_id, @contas, :id, :nome, {}, class: "form-select" %></div>
  <div class="col-md-6"><%= d.label :ativo_id, "Ativo" %><%= d.collection_select :ativo_id, @ativos, :id, :codigo, {}, class: "form-select" %></div>
  <div class="col-md-3"><%= d.label :natureza %><%= d.select :natureza, Operacao.naturezas.keys.map { |n| [n.humanize, n] }, {}, class: "form-select" %></div>
  <div class="col-md-3"><%= d.label :quantidade %><%= d.number_field :quantidade, step: :any, min: 0, class: "form-control" %></div>
  <div class="col-md-3"><%= d.label :preco_unitario %><%= d.number_field :preco_unitario, step: :any, min: 0, class: "form-control" %></div>
  <div class="col-md-3"><%= d.label :moeda_id, "Moeda" %><%= d.collection_select :moeda_id, @moedas, :id, :codigo, {}, class: "form-select" %></div>
  <div class="col-md-3"><%= d.label :data_negociacao %><%= d.date_field :data_negociacao, value: Date.current, class: "form-control" %></div>
  <div class="col-md-3"><%= d.label :data_liquidacao %><%= d.date_field :data_liquidacao, value: Date.current, class: "form-control" %></div>
  <% %i[taxa emolumentos corretagem iss_iof irrf outros].each do |campo| %>
    <div class="col-md-2"><%= d.label campo %><%= d.number_field campo, value: 0, step: :any, min: 0, class: "form-control" %></div>
  <% end %>
  <div class="col-md-3"><%= d.label :taxa_conversao_base %><%= d.number_field :taxa_conversao_base, value: 1, step: :any, min: 0, class: "form-control" %></div>
  <div class="col-md-3"><%= d.label :taxa_conversao_fiscal %><%= d.number_field :taxa_conversao_fiscal, value: 1, step: :any, min: 0, class: "form-control" %></div>
</div>
