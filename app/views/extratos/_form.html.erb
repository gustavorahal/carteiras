<%= render 'common/titulo_pagina', titulo: "Conta Corrente #{@conta_corrente.corretora.nome} carteira #{@carteira.nome} em #{@conta_corrente.moeda}" %>

<%= bootstrap_form_for [@conta_corrente, @extrato] do |f| %>
  <% if @extrato.errors[:base].present? %>
    <%= f.alert_message 'Favor corrigir o(s) erro(s) abaixo. ' + @extrato.errors[:base][0] %>
  <% else %>
    <%= f.alert_message 'Favor corrigir o(s) erro(s) abaixo.' %>
  <% end %>

  <%= hidden_field_tag 'extrato[conta_corrente_id]', @conta_corrente.id %>

  <%= f.date_select :liquidacao %>
  <%= f.date_select :movimentacao %>
  <%= f.text_field :descricao %>
  <%= f.number_field :valor, step: :any %>

  <%= f.submit "Adicionar" %>

<% end %>