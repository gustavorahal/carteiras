
<h4>Extrato <%= @corretora.nome %> - Saldo <%= @saldo %></h4>
<%= render 'common/btn_new', url: new_extrato_path(investidor_id: @investidor.id,
                                                   corretora_id: @corretora.id),
                                            label: 'Nova entrada' %>

<%= bootstrap_form_tag url: import_extratos_path do |f| %>
  <%= hidden_field_tag :investidor_id, @investidor.id %>
  <%= hidden_field_tag :corretora_id, @corretora.id %>
  <%= f.file_field :file, label: 'Importar extrato', placeholder: 'Arquivo de extrato' %>

  <%= f.submit 'Importar' %>
<% end %>

<table class="table table-striped table-sm">
    <thead class="thead-dark">
    <tr>
        <th scope="col">Liquidação</th>
        <th scope="col">Movimentação</th>
        <th scope="col">Descrição</th>
        <th scope="col">Valor</th>
    </tr>
    </thead>

    <tbody>
    <% @extratos.each do |extrato| %>
      <tr>
        <td><%= display_data extrato.liquidacao %></td>
        <td><%= display_data extrato.movimentacao %></td>
        <td><%= extrato.descricao %></td>
        <td><%= display_moeda extrato.valor, moeda: extrato.moeda, cores: true %></td>
      </tr>
    <% end %>
    </tbody>
</table>