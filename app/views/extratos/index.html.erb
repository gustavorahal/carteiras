
<h4>Extrato <%= @corretora %> - Saldo <%= @saldo %></h4>
<%= render 'common/btn_new', url: new_extrato_path(investidor_id: @investidor.id,
                                                   corretora: @corretora),
                                            btn_label: 'Nova entrada' %>


<table class="table table-striped table-sm">
    <thead class="thead-dark">
    <tr>
        <th scope="col">Liquidação</th>
        <th scope="col">Movimentação</th>
        <th scope="col">Descrição</th>
        <th scope="col">Valor</th>
    </tr>
    </thead>

    <tbody>
    <% book_atual = '' %>
    <% @extratos.each do |extrato| %>
      <tr>
        <td><%= display_data extrato.liquidacao %></td>
        <td><%= display_data extrato.movimentacao %></td>
        <td><%= extrato.descricao %></td>
        <td><%= display_moeda extrato.valor, moeda: extrato.moeda, cores: true %></td>
      </tr>
    <% end %>
    </tbody>
</table>