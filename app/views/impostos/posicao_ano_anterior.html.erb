<%= render 'common/titulo_pagina', titulo: "Posição em #{display_data @data} (em teste)" %>

<table class="table table-sm">
  <thead class="thead-dark">
  <tr>
    <th scope="col">Ativo</th>
    <th scope="col">Quantidade<br></th>
    <th scope="col">Preço Médio<br></th>
    <th scope="col">Valor investido<br></th>
    <th scope="col">Data montagem</th>
  </tr>
  </thead>

  <tbody>
  <% @carteira_ativos.ativos_posicao_por_corretora.each do |corretora_nome, tipos|  %>
    <tr class="table-primary">
      <td colspan="5">
        <h6><%= corretora_nome %></h6>
      </td>
    </tr>
    <% tipos.each do |tipo, ativos_posicoes| %>
      <tr class="table-dark">
        <td colspan="5">
          <h6><%= tipo.upcase %></h6>
        </td>
      </tr>
      <% ativos_posicoes.each do |ativo_posicao| %>
        <% ativo = ativo_posicao.ativo %>
        <tr>
          <td><%= link_to ativo.nome, carteira_ativo_path(@carteira, ativo) %></td>
          <td><%= display_numero ativo_posicao.quantidade %></td>
          <td><%= display_preco_medio ativo_posicao %></td>
          <td><%= display_valor_investido ativo_posicao %></td>
          <td><%= display_data ativo_posicao.data_montagem %></td>
        </tr>
      <% end %>
    <% end %>
  <% end %>
  </tbody>

</table>