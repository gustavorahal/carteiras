<%= render 'common/titulo_pagina', titulo: ['Proventos total de ', display_moeda(@total)]  %>

<h6>Rendimentos de FII, Dividendos e Juros sobre Capital</h6>
<br>
<h4>Mês a mês</h4>
<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th>Mês</th>
    <th>Total</th>
    <th>Rendimento</th>
    <th>Dividendo</th>
    <th>JCP</th>
  </tr>
  </thead>
  <tbody>
  <% @mes_a_mes_total.each do |mes, valor| %>
    <tr>
      <td><%= I18n.l mes, format: "%b %Y" %></td>
      <td class="table-primary"><strong><%= display_moeda valor %></strong></td>
      <td><%= display_moeda @mes_a_mes_rendimento[mes] %>
        <% if @total_fii_mes_a_mes[mes] %>
          (<%= display_moeda @total_fii_mes_a_mes[mes] %> em FIIs -
          <%= display_porcentagem @mes_a_mes_rendimento[mes]/@total_fii_mes_a_mes[mes] * 100 %>)
        <% end %>
      </td>
      <td><%= display_moeda @mes_a_mes_dividendo[mes] %></td>
      <td><%= display_moeda @mes_a_mes_jcp[mes] %></td>
    </tr>
  <% end %>
  </tbody>
</table>


<h4>Detalhamento</h4>
<table class="table table-striped table-sm">
  <thead class="thead-dark">
  <tr>
    <th>Data</th>
    <th>Ativo</th>
    <th>Evento</th>
    <th>Valor Líquido</th>
    <th>Acumulado</th>
    <th>Corretora</th>
  </tr>
  </thead>
  <tbody>
  <% acumulado = 0 %>
  <% @proventos.each do |provento| %>
    <% acumulado += provento.valor_liquido %>
    <tr>
      <td><%= display_data provento.data %></td>
      <td><%= provento.ativo.nome_amigavel %></td>
      <td><%= provento.evento %></td>
      <td><%= display_moeda provento.valor_liquido, moeda: provento.moeda %></td>
      <td><%= display_moeda acumulado, moeda: provento.moeda %></td>
      <td><%= provento.corretora.nome %></td>
    </tr>
  <% end %>
  </tbody>
</table>
