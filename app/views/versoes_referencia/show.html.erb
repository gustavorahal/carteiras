<h1><%= @referencia.nome %> — <%= l @versao.vigencia_inicial %></h1><p>Estado: <%= @versao.estado %></p>
<table class="table"><thead><tr><th>Ativo</th><th>Categoria</th><th>Percentual</th></tr></thead><tbody><% @alocacoes.each do |a| %><tr><td><%= a.ativo.codigo %></td><td><%= a.categoria %></td><td><%= a.percentual %>%</td></tr><% end %></tbody></table>
<%= button_to "Publicar", publicar_referencia_versoes_referencia_path(@referencia, @versao), class: "btn btn-primary" if policy(@versao).publicar? %>
